# ─── Spring ───────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ─── PostgreSQL ───────────────────────────────────────────
DB_NAME=thirdsector
DB_USERNAME=thirdsector
DB_PASSWORD=
DB_PORT=5432
DB_URL=jdbc:postgresql://localhost:5432/thirdsector

# ─── Redis ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Kafka (KRaft) ───────────────────────────────────────
# Gere um cluster ID com: docker run --rm apache/kafka:3.9.0 /opt/kafka/bin/kafka-storage.sh random-uuid
KAFKA_CLUSTER_ID=
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=third-sector-group

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRATION=86400000

# ─── MinIO ───────────────────────────────────────────────
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=third-sector

# ─── Mail / Mailpit ──────────────────────────────────────
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=dev@thirdsector.local
MAIL_PASSWORD=
MAILPIT_UI_PORT=8025
